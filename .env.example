# ──────────────────────────────────────────────────────────────────────────
# Lattice environment variables
# Copy to .env (git-ignored) and fill in. All secrets are SERVER-ONLY —
# never prefix a secret with NEXT_PUBLIC_. Do NOT put real values in this file.
# ──────────────────────────────────────────────────────────────────────────

# --- Database (Neon Postgres) ------------------------------------------------
# Pooled connection string used at runtime (serverless driver).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/lattice?sslmode=require"
# Direct (unpooled) string used by drizzle-kit migrations.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx.region.aws.neon.tech/lattice?sslmode=require"

# --- Auth (BetterAuth) -------------------------------------------------------
# openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-a-32-byte-base64-secret"
# Base URL of the app for this environment (no trailing slash).
BETTER_AUTH_URL="http://localhost:3000"
# GitHub OAuth app. Callback: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Storage (Vercel Blob) ---------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# --- AI (Vercel AI Gateway) --------------------------------------------------
# All model access goes through the Vercel AI Gateway: one credential reaches
# every provider, billed via Vercel. Models are referenced by `provider/model`
# slug (configurable here). On Vercel, deployments authenticate via OIDC and
# this key is NOT needed in production — set it only for local dev / non-Vercel.
AI_GATEWAY_API_KEY=""
CHAT_MODEL="anthropic/claude-opus-4.8"
EMBEDDING_MODEL="openai/text-embedding-3-small"   # 1536 dims — must match db vector size

# --- Background jobs (Inngest) -----------------------------------------------
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Public ------------------------------------------------------------------
# Safe to expose to the browser. Used for absolute links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
